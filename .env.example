# ============================================================
# Allo Inventory — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# --- PostgreSQL (Supabase / Neon / Railway) ---
# Connection pooling URL (used by Prisma at runtime)
DATABASE_URL="postgresql://user:password@host:5432/allo?pgbouncer=true&connection_limit=1"

# Direct connection URL (used by Prisma CLI for migrations)
DIRECT_URL="postgresql://user:password@host:5432/allo"

# --- Redis (Upstash) ---
# Required for distributed locking and idempotency caching.
# Leave blank to fall back to DB-only locking (still correct, less scalable).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- App URL ---
# Used by server components to call internal API routes.
# Set to your Vercel URL in production; leave as-is for local dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cron security ---
# Optional: set a secret and pass it as Bearer token when calling the cron endpoint.
CRON_SECRET=""
